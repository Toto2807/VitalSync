# Multi-stage build : le premier stage installe les dépendances et exécute les tests
# dans un environnement complet. Le second stage copie uniquement le code nécessaire
# à l'exécution dans une image alpine légère, sans les outils de développement ni
# les devDependencies. Cela réduit la surface d'attaque et la taille de l'image finale.

FROM node:20-alpine AS builder
WORKDIR /app
COPY package*.json ./
RUN npm ci
COPY . .
RUN npm test

FROM node:20-alpine AS production
WORKDIR /app
COPY package*.json ./
RUN npm ci --omit=dev
COPY --from=builder /app/server.js .
EXPOSE 3000
CMD ["node", "server.js"]